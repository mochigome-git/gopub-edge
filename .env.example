############
# Secrets 
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

APP_VERSION=

############
# MQTT (Subscriber — Mosquitto, receives raw PLC data)
############

MQTT_HOST=mqtt-host.com
MQTT_PORT=8883
MQTT_TOPIC="topic/+"
MQTTS_ON=true

# Topic gopub-edge publishes patch/upsert requests to.
LOCAL_VACUUM_REQUEST_TOPIC="gopub-edge/vacuum/request"
# Reply topic prefix for upsert requests. gopub-edge subscribes to
# <prefix>#; your reply engine publishes to <prefix><correlation_id>
# (the exact reply_topic sent in the request envelope). Plain "patch"
# requests have no reply_topic — nothing should reply to those.
MQTT_REPLY_TOPIC_PREFIX="gopub-edge/reply/"

# How long (seconds) gopub-edge waits for an upsert reply before giving up
# and logging a timeout. Does not apply to fire-and-forget "patch" requests.
MQTT_REPLY_TIMEOUT_SEC=10



ECS_MQTT_CA_CERTIFICATE="secret key"
ECS_MQTT_CLIENT_CERTIFICATE="secret key"
ECS_MQTT_PRIVATE_KEY="secret key"

############
# MQTT (Publisher — EMQX, sends insert/upsert requests downstream)
# This is a DIFFERENT broker from the subscriber above. gopub-edge
# publishes patch/upsert requests here instead of calling Supabase
# directly; gokafka-raw (or your reply engine) consumes them, does the
# insert, and — for upsert only — replies on EMQX_REPLY_TOPIC_PREFIX+<id>.
############

EMQX_HOST=emqx-host.com
EMQX_PORT=8883
EMQX_USERNAME="secret key"
EMQX_PASSWORD="secret key"
EMQX_TLS_ON=true

# Optional. Leave blank if EMQX_HOST's certificate is already trusted by
# the system, or if you're only using username/password auth (no mTLS).
EMQX_CA_CERTIFICATE=""
EMQX_CLIENT_CERTIFICATE=""
EMQX_PRIVATE_KEY=""

EMQX_INSERT_REQUEST_TOPIC="gopub-edge/devices/payload"

###########
# RestApi — LEGACY, no longer used by the insert path.
# Left here only in case you need to roll back to direct HTTP PATCH/POST
# against Supabase. Safe to delete once the MQTT path is confirmed stable.
###########

# usage = "http://localhost/rest/v1/tablename?id=eq.1"
API_URL="database endpoint"
SERVICE_ROLE_KEY="anon key"
# update call "PATCH"; insert call "POST"
BASH_API="POST"

###########
# Insert mode
###########

# "patch"  -> fire-and-forget publish, no reply expected
# "upsert" -> publish and block for a correlated reply (used for PLC write-back)
INSERT_MODE=patch

###########
# Data Collect Rules
###########

# Trigger Device format
# trigger + case option = trigger1,option1,tigger2.option2,
# Case option.
# 1. "time.duration" ; Calculate the start time and end time of the trigger and replace time duration as a payload.
# 2. "standard" ; Patch data to database if trigger is true 
# 3. "trigger" ; Fetch data for LOOPING secs and Patch data once trigger is true
# 4. "hold" ; Fetch the data and store it to diff map, combine into a single data and patch it.
# 5. "special"
# 6. "holdfilling"
# 7. "weight"
# 8. "holdfillingweight"
########
# hold example usage : 
# HOLD_KEY_TRANSOFRMATION_title1=device
# HOLD_KEY_TRANSOFRMATION_title2=device...

###########
# Usage only for case 4
###########

